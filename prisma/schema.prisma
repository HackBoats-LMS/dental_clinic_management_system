model Admin {
  adminId String @id @default(uuid())
  name String
  email String
  phone String?
}

model CallList {
  id String @id @default(uuid())
  name String
  phoneNumber String
  status String @default("PENDING") // PENDING, CONTACTED, NOT_LIFTED, OTHER
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}